# ── Core ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── WhatsApp (Meta Cloud API — the ONLY supported transport) ───────────────────
VERIFY_TOKEN=
WHATSAPP_TOKEN=
PHONE_NUMBER_ID=
# App Secret from Meta App → Settings → Basic. When set, incoming webhook
# payloads are verified via X-Hub-Signature-256 (forged requests are rejected).
META_APP_SECRET=

# ── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=

# ── Tenant resolution ──────────────────────────────────────────────────────────
# The integer db tenant id used for Supabase queries, and the folder key under
# tenants/ used for file config. Defaults come from tenants/registry.json.
DEFAULT_TENANT_ID=1
DEFAULT_TENANT_KEY=urbanwear

# ── Reminders ──────────────────────────────────────────────────────────────────
REMINDER_POLL_INTERVAL_MS=60000
MAX_PAYMENT_REMINDERS=4
MIN_HOURS_BETWEEN_REMINDERS=20

# ── Responses ──────────────────────────────────────────────────────────────────
RESPONSE_EMOJI_PROBABILITY=0.25
REVIEW_LINK=

# ── Translation (optional; set at least one path) ──────────────────────────────
AI4BHARAT_API_URL=
AI4BHARAT_API_KEY=
HUGGINGFACE_API_KEY=
AI4BHARAT_HF_EN_TO_INDIC_MODEL=ai4bharat/indictrans2-en-indic-1B
AI4BHARAT_HF_INDIC_TO_EN_MODEL=ai4bharat/indictrans2-indic-en-1B
